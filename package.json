{
  "name": "animated-badge",
  "version": "1.0.0",
  "description": "A framework-agnostic <animated-badge> Web Component with a code-driven animation constructor.",
  "type": "module",
  "main": "./dist/animated-badge.min.js",
  "module": "./dist/animated-badge.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/animated-badge.esm.js",
      "default": "./dist/animated-badge.min.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:lib && npm run build:site",
    "build:lib": "vite build --config vite.lib.config.ts && vite build --config vite.react.config.ts && tsc -p tsconfig.build.json",
    "build:site": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "badge",
    "animation"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dialkit": "^1.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
